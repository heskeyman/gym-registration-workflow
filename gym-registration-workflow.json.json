    {
      "parameters": {
        "jsCode": "// Get the input data\nconst input = $input.first().json;\n\n// Handle both nested { \"body\": ... } and flat { ... } formats\nconst data = input.body || input;\n\nreturn [{\n  json: {\n    full_name: data.full_name || \"New Member\",\n    email: data.email || \"\",\n    phone: data.phone || \"\",\n    plan_type: data.plan_type || \"monthly\",\n    amount_paid: data.amount_paid || 0,\n    start_date: new Date().toISOString().split('T')[0],\n    expiry_date: new Date(new Date().getTime() + 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
