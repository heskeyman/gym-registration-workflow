      "parameters": {
        "jsCode": "// 1. Get the original user data from the first Code node\n// (Ensure the name 'Validate & Prepare Data' matches your first Code node exactly!)\nconst originalData = $('Validate & Prepare Data').first().json;\n\n// 2. Get the search result from Airtable\nconst searchResult = $input.first().json;\n\n// 3. Check if we found a user\nlet status = 'new';\nif (searchResult.records && searchResult.records.length > 0) {\n  status = 'duplicate';\n}\n\n// 4. Return the data so the next node can use it\nreturn [{\n  json: {\n    ...originalData, // This restores all the user fields (name, email, etc.)\n    status: status   // This adds a status flag for the next IF node\n  }\n}];"
      },
